# Example environment file for ruvector-hailo-worker.
# Copy to /etc/ruvector-hailo.env and customise.
# The systemd unit reads this via EnvironmentFile=-.

# Listen address. 0.0.0.0:50051 is the cluster default; override to
# 127.0.0.1:N if you only want local clients, or to a tailnet-only IP
# (`tailscale ip -4` on the host) if you want tailnet-only access.
RUVECTOR_WORKER_BIND=0.0.0.0:50051

# Path to the directory containing model.hef + vocab.txt + special_tokens.json.
# Compiled by Hailo Dataflow Compiler on x86 (see crates/ruvector-hailo/models/README.md).
RUVECTOR_MODEL_DIR=/var/lib/ruvector-hailo/models/all-minilm-l6-v2

# Tracing filter — info is the production default; ruvector_hailo_worker=debug
# turns on per-RPC spans without flooding upstream noise.
RUST_LOG=info,ruvector_hailo_cluster=info,ruvector_hailo=info
