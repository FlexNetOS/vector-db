# Root .gitignore blocks `data/` and `.claude-flow/`; for this example we
# DO want to ship the seed corpus AND the claude-flow/omc state (it is
# persistent project state, not runtime junk).
!data/
!data/**
!.claude-flow/
!.claude-flow/**

# Local DB artifacts — regenerated by init.sh / seed-docs.mjs
*.db
*.db-*
agentdb.db*
vectors.db*

# Benchmark scratch
BENCHMARK_RESULTS.json

# Node noise
node_modules/
