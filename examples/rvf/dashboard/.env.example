# Dashboard environment flags
# Copy to `.env` (or `.env.local`) and run `npm run dev` to apply.

# When `true`, fetchStatus() returns a static plausible payload and the WS
# layer emits a few canned messages so the UI works offline (no backend).
# When `false` (default), the dashboard calls the real `/api/*` endpoints
# and connects to `/ws/live`.
VITE_MOCK_API=false
